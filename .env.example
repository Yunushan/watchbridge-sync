WATCHBRIDGE_PORT=8080
WATCHBRIDGE_API_KEY=replace-with-a-long-random-server-key
WATCHBRIDGE_BACKUP_DIR=.watchbridge-backups
WATCHBRIDGE_JOB_DIR=.watchbridge-jobs
# Optional: exactly 64 hex characters, 44-character padded Base64, or 43-character unpadded Base64URL.
# WATCHBRIDGE_STORAGE_KEY=replace-with-a-valid-32-byte-key
# One-time migration only: exact lowercase true permits validated plaintext records to be encrypted on read.
# WATCHBRIDGE_ALLOW_PLAINTEXT_STORAGE_MIGRATION=false
# High-risk owner opt-in: exact lowercase true permits request-supplied HTTPS provider base URLs.
# WATCHBRIDGE_ALLOW_CUSTOM_PROVIDER_BASE_URLS=false
