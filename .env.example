WATCHBRIDGE_PORT=8080
# Maximum drain time after SIGTERM/SIGINT before the API forces shutdown (1000-300000).
# WATCHBRIDGE_SHUTDOWN_TIMEOUT_MS=25000
# Client connection time bounds (1000-300000); header timeout cannot exceed request timeout.
# WATCHBRIDGE_HEADERS_TIMEOUT_MS=15000
# WATCHBRIDGE_REQUEST_TIMEOUT_MS=60000
# WATCHBRIDGE_KEEP_ALIVE_TIMEOUT_MS=5000
# Compose resource ceilings; tune only after load testing the deployment workload.
# WATCHBRIDGE_API_CPUS=1.0
# WATCHBRIDGE_API_MEMORY_LIMIT=1g
# WATCHBRIDGE_WEB_CPUS=0.5
# WATCHBRIDGE_WEB_MEMORY_LIMIT=256m
# Optional public HTTPS edge profile. Keep the base web listener loopback-only
# (for example WATCHBRIDGE_HTTP_PORT=127.0.0.1:18080) when this is enabled.
# WATCHBRIDGE_TLS_HTTP_PORT=80
# WATCHBRIDGE_TLS_HTTPS_PORT=443
# WATCHBRIDGE_EDGE_CPUS=0.25
# WATCHBRIDGE_EDGE_MEMORY_LIMIT=128m
# WATCHBRIDGE_TLS_CERTIFICATE_PATH=/secure/path/fullchain.pem
# WATCHBRIDGE_TLS_PRIVATE_KEY_PATH=/secure/path/privkey.pem
# Required in production: at least 32 non-whitespace characters from a secret manager.
WATCHBRIDGE_API_KEY=replace-with-a-long-random-server-key
# Multi-tenant alternative; do not set with WATCHBRIDGE_API_KEY. Tenant IDs use lowercase letters, digits, _ and -.
# WATCHBRIDGE_API_KEYS={"tenant-a":"replace-with-a-unique-32-character-key","tenant-b":"replace-with-a-second-unique-key"}
# Optional outside production; production defaults to 120 requests/minute per API authorization value.
# WATCHBRIDGE_RATE_LIMIT_PER_MINUTE=120
# Optional outside production; production defaults to 16 concurrent authenticated API requests.
# WATCHBRIDGE_MAX_CONCURRENT_REQUESTS=16
# Optional outside production; production defaults to two process-wide concurrent sync or restore operations.
# WATCHBRIDGE_MAX_CONCURRENT_SYNCS=2
WATCHBRIDGE_BACKUP_DIR=.watchbridge-backups
WATCHBRIDGE_JOB_DIR=.watchbridge-jobs
# Optional: exactly 64 hex characters, 44-character padded Base64, or 43-character unpadded Base64URL.
# WATCHBRIDGE_STORAGE_KEY=replace-with-a-valid-32-byte-key
# One-time migration only: exact lowercase true permits validated plaintext records to be encrypted on read.
# WATCHBRIDGE_ALLOW_PLAINTEXT_STORAGE_MIGRATION=false
# High-risk owner opt-in: exact lowercase true permits request-supplied HTTPS provider base URLs.
# WATCHBRIDGE_ALLOW_CUSTOM_PROVIDER_BASE_URLS=false
